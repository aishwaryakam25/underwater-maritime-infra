# NautiCAI Backend — optional env for production (AWS App Runner / EC2)
# Set in AWS Console or in the task/container definition.

# Base URL of this API (for WhatsApp report download links). No trailing slash.
# NAUTICAI_BASE_URL=https://your-api.us-east-1.awsapprunner.com

# WhatsApp via Twilio (optional — without these, signup/detection/PDF still work; WhatsApp returns "not configured")
# Copy this file to .env and set your real values. Backend loads backend/.env automatically.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

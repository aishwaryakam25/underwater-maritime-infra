# NautiCAI Frontend — set these for production build (AWS deploy)
# Copy to .env or set in CI/Amplify before npm run build

# Backend API base URL (no trailing slash). Required for detection, PDF, WhatsApp.
REACT_APP_API_URL=https://your-api.us-east-1.awsapprunner.com

# Where the demo signup gate lives. After signup, user is sent here then to the app.
REACT_APP_DEMO_GATE_URL=https://www.yourdomain.com/demo.html
